+        # no-ops when there is no clean matching session.
+        if delivered:
+            try:
+                from gateway.mirror import mirror_to_session
+                _origin = _resolve_origin(job) or {}
+                mirror_to_session(
+                    platform_name,
+                    chat_id,
+                    cleaned_delivery_content,
+                    source_label="cron",
+                    thread_id=thread_id,
+                    user_id=_origin.get("user_id"),
+                )
+            except Exception:
+                pass
 
     if delivery_errors:
         return "; ".join(delivery_errors)
