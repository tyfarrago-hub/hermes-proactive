             logger.info("Job '%s': delivered to %s:%s", job["id"], platform_name, chat_id)
+            delivered = True
+
+        # LOCAL PATCH (mirror-cron-deliveries): record proactive/cron sends into
+        # the target chat's session transcript so a later short reply ("Remind me")
